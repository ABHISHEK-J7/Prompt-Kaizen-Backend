# --- Server ---
PORT=5000

# --- Database ---
# Connection string for your MongoDB Atlas cluster or local mongod.
MONGO_URI=mongodb://127.0.0.1:27017/prompt_kaizen

# --- Auth ---
# IMPORTANT: replace with a long random secret in production.
JWT_SECRET=replace_this_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed origins. Add the user frontend (5173)
# and the admin frontend (5174) for local development.
CLIENT_URL=http://localhost:5173,http://localhost:5174

# --- Admin seed (used by `npm run seed:admin`) ---
# ADMIN_EMAIL doubles as the login identifier and can be a simple username
# (e.g. "Admin") or a real email address. Set ADMIN_RESET_PASSWORD=true to
# force the password to be reset every time the seed script runs.
ADMIN_NAME=Admin
ADMIN_EMAIL=Admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_RESET_PASSWORD=true
